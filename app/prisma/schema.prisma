// TimeFlow — Prisma Schema
// UTC en toda la BBDD. Zona horaria del cliente se aplica solo en UI.

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Task {
  id        String   @id @default(cuid())
  title     String
  startTime DateTime? @db.Timestamptz
  endTime   DateTime? @db.Timestamptz
  color     String   @default("#6366f1")
  iconId    String   @default("default")
  done      Boolean  @default(false)
  googleEventId String? @unique
  // Inbox / Google Tasks sync
  googleTaskId   String?   @unique
  status         String    @default("pending")
  archived       Boolean   @default(false)
  // Metadatos enriquecidos (IA)
  duration        Int?      // Minutos estimados
  urgency        Int?      // 1-5
  importance     Int?      // 1-5
  mentalNoise    Int?      // 1-5 (carga cognitiva)
  // Programación (para scheduler IA)
  scheduledStart DateTime? @db.Timestamptz
  scheduledEnd   DateTime? @db.Timestamptz
  // Orden en vista Inbox
  inboxOrder     Int       @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  // Tags
  tags     TaskTag[]

  @@map("tasks")
}

model MotorConfig {
  id              String   @id @default("default")
  calendarIds      String   @default("{}") // JSON string: {"alex":"...","adriana":"...","colegios":"...","ninos":"..."}
  promptIA         String   @default("")
  googleConnected  Boolean  @default(false)
  googleTokens     String   @default("{}") // JSON encrypted tokens
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("motor_config")
}

model Disponibilidad {
  id          String   @id @default(cuid())
  diaSemana   Int      // 0=Dom, 1=Lun, ... 6=Sáb
  horaInicio  Int      // hora inicio (0-23)
  horaFin     Int      // hora fin (1-24)
  tipo        String   @default("TOTAL") // TOTAL | PARCIAL | OCUPADO
  label       String   @default("")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("disponibilidad")
}

model Tag {
  id        String   @id @default(cuid())
  name      String   @unique
  color     String   @default("#6366f1")
  createdAt DateTime @default(now()) @map("created_at")
  tasks     TaskTag[]

  @@map("tags")
}

model TaskTag {
  taskId String
  tagId  String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([taskId, tagId])
  @@map("task_tags")
}
